{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task|Edit|MultiEdit|Write|create",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guards/subagents/subagents.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/prompts/tests/tests.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scripts/format/format.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scripts/lint/lint.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scripts/build/build.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scripts/test/test.sh"
          }
        ]
      }
    ]
  }
}
