{
  "name": "@e-xode/vue-ssr",
  "version": "5.3.0",
  "description": "Vue 3 SSR Starter Kit with Authentication",
  "repository": {
    "type": "git",
    "url": "https://github.com/e-xode/vue-ssr"
  },
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env --watch-path=./server.js server.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --outDir dist/client --ssrManifest",
    "build:server": "vite build --ssr src/entry-server.js --outDir dist/server",
    "prod": "cross-env NODE_ENV=production node server.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --cache . --fix",
    "lint:check": "eslint --cache .",
    "format": "prettier --cache --write .",
    "format:check": "prettier --cache --check .",
    "validate": "node scripts/validate.mjs",
    "screenshots": "node .claude/skills/brand-art-direction/scripts/screenshots.mjs"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@mdi/js": "^7.4.47",
    "@vitejs/plugin-vue": "^6.0.7",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dompurify": "^3.4.11",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "mongodb": "^7.2.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "pinia": "^3.0.4",
    "sanitize-html": "^2.17.6",
    "session-file-store": "^1.5.0",
    "sirv": "^3.0.2",
    "vite": "^8.0.16",
    "vue": "^3.5.40",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7",
    "vuetify": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/vue": "^8.1.0",
    "@vitest/ui": "^4.1.8",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "sass-embedded": "^1.100.0",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "bn.js": "^5.2.3",
    "minimatch": "^10.2.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "vue",
    "ssr",
    "starter-kit",
    "boilerplate",
    "authentication"
  ],
  "license": "MIT"
}
