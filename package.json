{
  "name": "@e-xode/vue-ssr",
  "version": "3.0.2",
  "description": "Vue 3 SSR Starter Kit with Authentication",
  "repository": {
    "type": "git",
    "url": "https://github.com/e-xode/vue-ssr"
  },
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "dev": "node server.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --outDir dist/client --ssrManifest",
    "build:server": "vite build --ssr src/entry-server.js --outDir dist/server",
    "prod": "cross-env NODE_ENV=production node server.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --fix",
    "lint:check": "eslint ."
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "@vitejs/plugin-vue": "^6.0.5",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dompurify": "^3.3.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "mongodb": "^7.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.3",
    "pinia": "^3.0.4",
    "session-file-store": "^1.5.0",
    "sirv": "^3.0.2",
    "vite": "^7.1.1",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4",
    "vuetify": "^4.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/vue": "^8.1.0",
    "@vitest/ui": "^4.1.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.4",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.98.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "bn.js": "^5.2.3",
    "minimatch": "^10.2.2"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "vue",
    "ssr",
    "starter-kit",
    "boilerplate",
    "authentication"
  ],
  "license": "MIT"
}
